# Desktop private default LLM seed.
#
# Copy this file to desktop_seed.env when building a private desktop package.
# The real desktop_seed.env file is ignored by git via the repository-wide
# *.env rule. Do not commit real API keys.

# CWS_DEFAULT_LLM_BASE_URL=https://api.example.com/v1
# CWS_DEFAULT_LLM_MODEL=example-model
# CWS_DEFAULT_LLM_FAST_MODEL=example-fast-model
# CWS_DEFAULT_LLM_API_FORMAT=openai
# CWS_DEFAULT_LLM_MODE=custom
# CWS_DEFAULT_LLM_MAX_CONCURRENT_REQUESTS=3
# CWS_DEFAULT_LLM_API_KEY=your_private_key_here
