# Epic Games Store BuildPatchTool settings.
# ========================================
# Copy this file to epic_config.env and fill in your real Epic product fields.
# The real epic_config.env file is ignored by git via the repository-wide
# *.env rule.

# Absolute path to the official BuildPatchTool.exe.
EPIC_BUILD_PATCH_TOOL_PATH=E:\epic-patch-tool\Engine\Binaries\Win64\BuildPatchTool.exe

# Product identifiers from the Epic Developer Portal.
EPIC_ORGANIZATION_ID=your_organization_id
EPIC_PRODUCT_ID=your_product_id
EPIC_ARTIFACT_ID=your_artifact_id

# OAuth client allowed to upload binaries for this product/artifact.
EPIC_CLIENT_ID=your_client_id

# Do not put the real secret in this file. Set this environment variable in
# the terminal before running a real upload:
#   $env:EPIC_CLIENT_SECRET = "..."
EPIC_CLIENT_SECRET_ENV_VAR=EPIC_CLIENT_SECRET

# Local cache directory used by BuildPatchTool to reuse patch chunks.
EPIC_CLOUD_DIR=tmp\epic\cloud

# Executable path relative to the packaged content root.
EPIC_APP_LAUNCH=CultivationWorldSimulator.exe
EPIC_APP_ARGS=

# Optional: BuildRoot-relative ignore list file.
# EPIC_FILE_IGNORE_LIST=tools\package\epic\file_ignore.txt
