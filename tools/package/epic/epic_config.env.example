# Epic Games Store distribution settings placeholder.
#
# Copy this file to epic_config.env after the Epic distribution tooling is
# installed and the exact upload command is decided. The real epic_config.env
# file is ignored by git via the repository-wide *.env rule.

# EPIC_UPLOAD_TOOL_PATH=C:\path\to\epic\upload\tool.exe
# EPIC_ORGANIZATION_ID=
# EPIC_PRODUCT_ID=
# EPIC_ARTIFACT_ID=
# EPIC_CLIENT_ID=
# EPIC_CLIENT_SECRET=
