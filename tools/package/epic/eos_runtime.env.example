# Epic EOS runtime settings.
# ========================================
# Copy this file to eos_runtime.env and fill in real values locally.
# The real eos_runtime.env file is ignored by git via the repository-wide
# *.env rule. Do not commit client secrets.

EPIC_EOS_PRODUCT_ID=
EPIC_EOS_SANDBOX_ID=

# Active fallback deployment used by local/dev packaging when an explicit
# EPIC_EOS_<ENV>_DEPLOYMENT_ID value is not available.
EPIC_EOS_DEPLOYMENT_ID=
EPIC_EOS_DEV_DEPLOYMENT_ID=
EPIC_EOS_LIVE_DEPLOYMENT_ID=

# Runtime client credentials for the desktop game client. Do not reuse the
# BuildPatchTool upload client here.
EPIC_EOS_CLIENT_ID=
EPIC_EOS_CLIENT_SECRET=

# Optional path to a prepared helper directory. When omitted, packaging looks at
# desktop-eos-helper\publish\win-x64.
# EPIC_EOS_HELPER_DIR=
