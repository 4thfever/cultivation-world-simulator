# Steamworks 开发者配置
# ========================
# 提示：复制此文件重命名为 steam_config.env，并在其中填入你的实际信息。
# steam_config.env 已经被 .gitignore 忽略，以防泄露密码和敏感 ID。

# 你的 Steam 登录账号 (建议创建一个专门用于打包的无两步验证子账号)
STEAM_USERNAME=your_build_account_name

# [可选] 你的 Steam 登录密码。如果不填，脚本运行时会弹窗安全提示你输入
# STEAM_PASSWORD=your_build_account_password

# 你的游戏的主 App ID
STEAM_APP_ID=1234567

# 你的游戏的 Depot ID (通常是在 App ID 基础上 +1，具体请查阅 Steamworks 后台)
STEAM_DEPOT_ID=1234568

# steamcmd.exe 的绝对路径，请指向你下载的 Steamworks SDK 中的 builder 文件夹
# 例如: D:\Steamworks_SDK\tools\ContentBuilder\builder\steamcmd.exe
STEAM_CMD_PATH=C:\path\to\your\steamworks_sdk\tools\ContentBuilder\builder\steamcmd.exe

# 默认 LLM seed 已迁移到 tools/package/desktop/desktop_seed.env。
# Steam 上传配置文件只保存 Steamworks/SteamCMD 字段。
