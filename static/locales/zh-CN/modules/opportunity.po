msgid "nearby"
msgstr "近处"

msgid "northeast"
msgstr "东北"

msgid "northwest"
msgstr "西北"

msgid "southeast"
msgstr "东南"

msgid "southwest"
msgstr "西南"

msgid "old city"
msgstr "古城"

msgid "sect territory"
msgstr "宗门之地"

msgid "cave dwelling"
msgstr "洞府"

msgid "wilderness place"
msgstr "荒僻之地"

msgid "unknown place"
msgstr "未知之地"

msgid "unknown realm"
msgstr "未知境界"

msgid "{realm} cultivator"
msgstr "{realm}修士"

msgid "{realm} {weapon_type} cultivator"
msgstr "{realm}{weapon_type}修"

msgid "{realm} sect cultivator"
msgstr "{realm}宗门修士"

msgid ""
"{avatar_name} felt a stir of fate, sensing a thread of opportunity tied to a "
"{region_hint} in the {direction}."
msgstr "{avatar_name}福至心灵，隐约感到一线机缘与{direction}一处{region_hint}相牵。"

msgid ""
"{avatar_name} felt a stir of fate, sensing a thread of opportunity tied to a "
"{target_hint} in the {direction}."
msgstr "{avatar_name}心有所感，似有一线机缘系于{direction}某位{target_hint}。"

msgid ""
"{avatar_name}'s opportunity sense gradually faded away."
msgstr "{avatar_name}心头那缕机缘感应渐渐散去，终究未能寻得。"

msgid ""
"{avatar_name}'s opportunity sense suddenly broke, leaving nowhere to seek."
msgstr "{avatar_name}心头那缕机缘感应骤然断绝，终究无从寻起。"

msgid ""
"{avatar_name} followed the opportunity and found an ancient treasure: "
"{item_name}."
msgstr "{avatar_name}循着机缘而至，得见古修遗物：{item_name}。"

msgid ""
"{avatar_name} followed the opportunity and obtained {item_name}. "
"{exchange_text}"
msgstr "{avatar_name}循着机缘而至，获得了{item_name}。{exchange_text}"

msgid ""
"{avatar_name} followed the opportunity and gained a boon: {boon_title}."
msgstr "{avatar_name}循着机缘有所悟，气机洗练，获得助益：{boon_title}。"

msgid ""
"{avatar_name} followed the opportunity, but the spiritual trace faded away."
msgstr "{avatar_name}循着机缘而至，却只见灵机散尽，终究无所得。"

msgid ""
"{avatar_name} followed the feeling, but only found the spiritual trace "
"already gone."
msgstr "{avatar_name}循着感应而至，却只见灵机散尽，终究无所得。"

msgid ""
"{avatar_name} followed the opportunity, but suffered backlash and was injured "
"for {damage} HP."
msgstr "{avatar_name}循着机缘而至，却遭残留凶险反噬，受伤 {damage} 点。"

msgid ""
"{avatar_name} followed the opportunity, but suffered backlash and perished."
msgstr "{avatar_name}循着机缘而至，却遭残留凶险反噬，身死道消。"

msgid "opportunity_boon"
msgstr "机缘助益"

msgid "opportunity_story_prompt"
msgstr "请围绕这次机缘结算写一段短小仙侠故事，突出天机牵引、角色当下处境与结果本身。不要改写已经发生的事实。"

msgid "{years} years and {months} months"
msgstr "{years}年{months}个月"

msgid "{years} years"
msgstr "{years}年"

msgid "{months} months"
msgstr "{months}个月"

msgid "Opportunity sense: {hint} This sense may last about {remaining}."
msgstr "机缘感应：{hint}此感应约还可维持{remaining}。"

msgid "effect_extra_opportunity_probability"
msgstr "机缘概率 +{value}"

msgid "effect_source_opportunity"
msgstr "机缘"
