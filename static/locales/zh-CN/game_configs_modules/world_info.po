#. 若当前年龄达到最大寿元，会立刻死亡。突破境界可以增加最大寿元，突破失败也可能折损寿元。
msgid "WORLD_INFO_LIFESPAN_DESC"
msgstr "每个角色都有寿元上限。寿元耗尽时会死亡；突破境界通常能延长寿元，突破失败也可能折损寿元。"

#. world_info.csv: 寿元
msgid "WORLD_INFO_LIFESPAN_NAME"
msgstr "寿元"

#. world_info.csv: 寿元
msgid "WORLD_INFO_LIFESPAN_TITLE"
msgstr "寿元"

#. world_info.csv: 道、佛、儒等根本理念，决定门牌的根脚与修行起源。
msgid "WORLD_INFO_ORTHODOXY_DESC"
msgstr "不同的道统有不同的修行方法。道家吐纳，武家锻体，佛家禅定，儒家教化民众。"

#. world_info.csv: 道统
msgid "WORLD_INFO_ORTHODOXY_NAME"
msgstr "道统"

#. world_info.csv: 道统
msgid "WORLD_INFO_ORTHODOXY_TITLE"
msgstr "道统"

#. world_info.csv: 修仙的境界从弱到强：练气、筑基、金丹、元婴。每个境界分前期、中期、后期。境界间差距很大。
msgid "WORLD_INFO_REALM_DESC"
msgstr "世界底层境界从弱到强为练气、筑基、金丹、元婴，每境分前期、中期、后期。不同道统可有别名，但规则计算仍以这套标准序列为准。"

#. world_info.csv: 境界
msgid "WORLD_INFO_REALM_NAME"
msgstr "境界"

#. world_info.csv: 境界
msgid "WORLD_INFO_REALM_TITLE"
msgstr "境界"

#. world_info.csv: 不同区域有不同效果，在适当的区域做适当的事情事半功倍。
msgid "WORLD_INFO_REGION_DESC"
msgstr "不同区域有不同效果，在适当的区域做适当的事情事半功倍。"

#. world_info.csv: 区域
msgid "WORLD_INFO_REGION_NAME"
msgstr "区域"

#. world_info.csv: 区域
msgid "WORLD_INFO_REGION_TITLE"
msgstr "区域"

#. 灵根由五行元素（金、木、水、火、土）组成，分为单灵根、双灵根和天灵根。五行相克：金克木，木克土，土克水，水克火，火克金。天灵根包含全部五行元素且突破时有额外加成。在与自身灵根属性匹配的区域修炼效率最高。
msgid "WORLD_INFO_ROOT_DESC"
msgstr ""
"灵根由五行元素（金、木、水、火、土）组成，分为单灵根、双灵根和天灵根。五行相克：金克木，木克土，土克水，水克火，火克金。天灵根包含全部五行元素且突破时有额外加成。在与自身灵根属性匹配的区域修炼效率最高。"

#. world_info.csv: 灵根
msgid "WORLD_INFO_ROOT_NAME"
msgstr "灵根"

#. world_info.csv: 灵根
msgid "WORLD_INFO_ROOT_TITLE"
msgstr "灵根"

#. world_info.csv: 每隔数年会有秘境开启。进入秘境可能遭遇凶险，也可能获得高阶法宝和功法。
msgid "WORLD_INFO_SECRET_REALM_DESC"
msgstr "每隔数年会有秘境开启。进入秘境可能遭遇凶险，也可能获得高阶法宝和功法。"

#. world_info.csv: 秘境
msgid "WORLD_INFO_SECRET_REALM_NAME"
msgstr "秘境"

#. world_info.csv: 秘境
msgid "WORLD_INFO_SECRET_REALM_TITLE"
msgstr "秘境"

#. world_info.csv: 修士的庇护所。加入宗门可习得独门功法、获同门庇护；散修自由但资源匮乏。
msgid "WORLD_INFO_SECT_DESC"
msgstr "修士的庇护所。加入宗门可习得独门功法、获同门庇护；散修自由但资源匮乏。"

#. world_info.csv: 宗门
msgid "WORLD_INFO_SECT_NAME"
msgstr "宗门"

#. world_info.csv: 宗门
msgid "WORLD_INFO_SECT_TITLE"
msgstr "宗门"

#. world_info.csv: 在城市区域可以购买练气级别丹药、兵器。购买丹药后会立刻服用强化自身。购买兵器可以帮自己切换兵器类型为顺手的类型。
msgid "WORLD_INFO_SHOPPING_DESC"
msgstr "在城市区域可以购买练气品阶的丹药与兵器。购买丹药后会立刻服用以强化自身；购买兵器可切换为更顺手的兵器类型。"

#. world_info.csv: 购物
msgid "WORLD_INFO_SHOPPING_NAME"
msgstr "购物"

#. world_info.csv: 购物
msgid "WORLD_INFO_SHOPPING_TITLE"
msgstr "购物"

#. world_info.csv: 修仙界的通用货币。可用于购买法宝丹药，通过采集、交易或掠夺获取。
msgid "WORLD_INFO_SPIRIT_STONE_DESC"
msgstr "修仙界的通用货币。可用于购买法宝丹药，通过采集、交易或掠夺获取。"

#. world_info.csv: 灵石
msgid "WORLD_INFO_SPIRIT_STONE_NAME"
msgstr "灵石"

#. world_info.csv: 灵石
msgid "WORLD_INFO_SPIRIT_STONE_TITLE"
msgstr "灵石"

#. world_info.csv: 世界每隔数年会有一次天象变动（如灵气潮汐），影响角色能力。
msgid "WORLD_INFO_WORLD_QI_DESC"
msgstr "世界每隔数年会有一次天象变动（如灵气潮汐），影响角色能力。"

#. world_info.csv: 天地灵机
msgid "WORLD_INFO_WORLD_QI_NAME"
msgstr "天地灵机"

#. world_info.csv: 天地灵机
msgid "WORLD_INFO_WORLD_QI_TITLE"
msgstr "天地灵机"

#. world_info.csv: 修仙界设有天地人三榜及宗门榜。天榜收录元婴期强者，地榜收录金丹期强者，人榜收录筑基期强者，宗门榜按宗门总实力排名。
msgid "WORLD_INFO_RANKING_DESC"
msgstr "修仙界设有天地人三榜及宗门榜。天地人三榜按等价标准境界划分：天榜收录元婴层级强者，地榜收录金丹层级强者，人榜收录筑基层级强者；宗门榜按宗门总实力排名。"

#. world_info.csv: 排行榜
msgid "WORLD_INFO_RANKING_NAME"
msgstr "排行榜"

#. world_info.csv: 排行榜
msgid "WORLD_INFO_RANKING_TITLE"
msgstr "排行榜"

#. world_info.csv: 凡人王朝统御天下，维持凡俗秩序与疆域。皇帝寿元与普通凡人无异，驾崩后会有新帝继位。
msgid "WORLD_INFO_DYNASTY_DESC"
msgstr "凡人王朝统御天下，维持凡俗秩序与疆域。皇帝寿元与普通凡人无异，驾崩后会有新帝继位。"

#. world_info.csv: 王朝
msgid "WORLD_INFO_DYNASTY_NAME"
msgstr "王朝"

#. world_info.csv: 王朝
msgid "WORLD_INFO_DYNASTY_TITLE"
msgstr "王朝"

#. world_info.csv: 修士可为朝廷理政，积累朝廷威望并领取俸禄。威望足够可升官，官职越高，俸禄与气运越多；久不理政，威望会逐渐下滑。
msgid "WORLD_INFO_OFFICIAL_DESC"
msgstr "修士可为朝廷理政，积累朝廷威望并领取俸禄。威望足够可升官，官职越高，俸禄与气运越多；久不理政，威望会逐渐下滑。"

#. world_info.csv: 官职
msgid "WORLD_INFO_OFFICIAL_NAME"
msgstr "官职"

#. world_info.csv: 官职
msgid "WORLD_INFO_OFFICIAL_TITLE"
msgstr "官职"

#. world_info.csv: 同一修行阶层在不同体系中有各自名目：道家与散修为练气、筑基、金丹、元婴；武道为淬体、易筋、宗师、武圣；儒道为养气、明理、立命、大儒；佛道为沙弥、比丘、罗汉、菩萨；妖族为开灵、化形、妖丹、妖王。它们彼此对应的是同一套底层境界序列，只改变叙事与界面称谓，不改变突破、战力、寿元、物品品阶等规则。
msgid "WORLD_INFO_CULTIVATION_ALIAS_DESC"
msgstr "同一修行阶层在不同体系中有各自名目：道家与散修为练气、筑基、金丹、元婴；武道为淬体、易筋、宗师、武圣；儒道为养气、明理、立命、大儒；佛道为沙弥、比丘、罗汉、菩萨；妖族为开灵、化形、妖丹、妖王。它们彼此对应的是同一套底层境界序列，只改变叙事与界面称谓，不改变突破、战力、寿元、物品品阶等规则。"

#. world_info.csv: 阶层别名
msgid "WORLD_INFO_CULTIVATION_ALIAS_NAME"
msgstr "阶层别名"

#. world_info.csv: 阶层别名
msgid "WORLD_INFO_CULTIVATION_ALIAS_TITLE"
msgstr "阶层别名"

#. world_info.csv: 蛊术需要修士持有蛊具并拥有下蛊能力，才能对可观测目标施加蛊。
msgid "WORLD_INFO_GU_DESC"
msgstr "蛊术需要修士持有蛊具并拥有下蛊能力，才能对可观测目标施加蛊。不同蛊有不同发作方式：潜心蛊会潜移默化影响关系，噬血蛊会周期性损伤生命，蚀元蛊与乱心蛊会侵扰修为。下蛊有成功率，受蛊具、施术者加成与目标抗蛊能力影响；失败时可能被目标察觉并损害关系。"

#. world_info.csv: 蛊
msgid "WORLD_INFO_GU_NAME"
msgstr "蛊"

#. world_info.csv: 蛊
msgid "WORLD_INFO_GU_TITLE"
msgstr "蛊"

#. world_info.csv: 阵法需要修士持有阵盘并拥有布阵能力，才能在当前区域布置限时区域效果。
msgid "WORLD_INFO_FORMATION_DESC"
msgstr "阵法需要修士持有阵盘并拥有布阵能力，才能在当前区域布置限时区域效果。不同阵法适合不同区域：修行地与宗门可布聚灵、守山、明心等阵；城市可布疗愈阵；矿脉、药田、兽域可布对应的寻脉、生木、驱兽阵。阵法会消耗灵石，并在持续时间结束后失效。"

#. world_info.csv: 阵法
msgid "WORLD_INFO_FORMATION_NAME"
msgstr "阵法"

#. world_info.csv: 阵法
msgid "WORLD_INFO_FORMATION_TITLE"
msgstr "阵法"