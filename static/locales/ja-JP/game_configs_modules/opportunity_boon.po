msgid "OPPORTUNITY_BOON_LUCK_TITLE"
msgstr "天機の加護"

msgid "OPPORTUNITY_BOON_LUCK_DESC"
msgstr "一筋の天機が命数を洗練し、運気をわずかに高める。"

msgid "OPPORTUNITY_BOON_LIFESPAN_TITLE"
msgstr "延寿の霊機"

msgid "OPPORTUNITY_BOON_LIFESPAN_DESC"
msgstr "霊機が身に入り、寿元がわずかに延びる。"

msgid "OPPORTUNITY_BOON_CULTIVATION_TITLE"
msgstr "悟道の余韻"

msgid "OPPORTUNITY_BOON_CULTIVATION_DESC"
msgstr "心神が澄み、数年のあいだ修行が入境しやすくなる。"

msgid "OPPORTUNITY_BOON_BODY_TITLE"
msgstr "霊機淬体"

msgid "OPPORTUNITY_BOON_BODY_DESC"
msgstr "霊機が体魄を鍛え、数年のあいだ戦力を高める。"
