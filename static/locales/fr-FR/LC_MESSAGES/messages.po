msgstr "Repos Expérience de cultivation"

msgid "effect_extra_rest_hp_recovery_rate"
msgstr "Taux de récupération des PV au repos"

msgid "effect_extra_eat_mortals_exp_multiplier"
msgstr "Multiplicateur d'expérience de dévorage des mortels"

msgid "effect_extra_cross_race_friendliness"
msgstr "Modificateur d'amabilité initiale entre races"
