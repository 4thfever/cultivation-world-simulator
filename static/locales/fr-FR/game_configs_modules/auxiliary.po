msgid "AUXILIARY_2073_DESC"
msgstr "Une boîte à Gu combinant mécanismes et arts Gu, adaptée pour l'infliction occulte de Gu."

msgid "AUXILIARY_2073_NAME"
msgstr "Boîte à Gu aux Mille Mécanismes"

msgid "AUXILIARY_2074_DESC"
msgstr "Un nid de reproduction occupé par les Gu-mères, capable de commander de nombreux Gu."

