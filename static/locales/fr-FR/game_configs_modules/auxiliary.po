msgid "AUXILIARY_2081_DESC"
msgstr "Un disque de formation gravé de motifs d'appel d'esprits basiques, capable d'exploiter l'énergie spirituelle locale pour établir une formation temporaire."

msgid "AUXILIARY_2081_NAME"
msgstr "Disque de Formation d'Appel d'Esprits"

msgid "AUXILIARY_2082_DESC"
msgstr "Ses motifs se connectent aux lignes telluriques peu profondes, rendant les formations plus stables et améliorant légèrement leur puissance et durée."

msgid "AUXILIARY_2082_NAME"
msgstr "Disque de Formation de Convergence des Lignes Telluriques"

msgid "AUXILIARY_2083_DESC"
msgstr "Les motifs du pivot mystique coordonnent plusieurs circuits spirituels, renforçant les formations et réduisant une partie de leur consommation de pierres spirituelles."

msgid "AUXILIARY_2083_NAME"
msgstr "Disque de Formation du Pivot Mystique"

msgid "AUXILIARY_2084_DESC"
msgstr "Ses motifs spirituels forment un cycle auto-contenu, attirant l'énergie spirituelle du vide pour améliorer grandement la puissance, la durée et l'efficacité des formations."

msgid "AUXILIARY_2084_NAME"
msgstr "Disque de Formation du Grand Vide"

msgid "AUXILIARY_2071_DESC"
