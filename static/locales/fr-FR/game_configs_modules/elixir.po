msgid "ELIXIR_3002_DESC"
msgstr ""
"Un élixir spirituel contenant la véritable essence de l'Établissement des "
"Fondations pour aider les cultivateurs au stade d'Établissement des Fondations"
" à surmonter les goulots d'étranglement (l'effet dure 5 ans)."

#. elixir.csv: 筑基破境丹
msgid "ELIXIR_3002_NAME"
msgstr "Élixir de Percée d'Établissement des Fondations"

#. elixir.csv: 凝结金丹之气，辅助金丹期修士碎丹成婴（药...
msgid "ELIXIR_3003_DESC"
msgstr ""
"Condense le qi de la Formation du Noyau pour aider les cultivateurs au stade "
"de Formation du Noyau à briser le noyau et former l'âme (l'effet dure 5 ans)."

#. elixir.csv: 金丹破境丹
msgid "ELIXIR_3003_NAME"
msgstr "Élixir de Percée de Formation du Noyau"

