# Event Content
msgid ""
"In the auction for {item_name}, {winner_name} outbid {runner_up_name} with "
"{price} spirit stones and won the item."
msgstr ""
"Lors de la mise aux enchères pour {item_name}, {winner_name} a surenchéri {runner_up_name} avec "
"{price} pierres spirituelles et a remporté l'objet."

msgid "Retreat Bonus"
msgstr "Illumination de Retraite"

# Additional Missing Translations
msgid "Unsupported item type: {item_type}"
msgstr "Type d'objet non supporté : {item_type}"

msgid "retreat_action_name"
msgstr "Retraite"

msgid "retreat_death_append"
msgstr ""
" Et a épuisé les dernières traces de sa vitalité en retraite, s'est éteint."

msgid "retreat_desc"
msgstr ""
"Retraite, pour briser les limites de soi. Extrêmement risqué, uniquement pour "
"ceux doués d'une grande persévérance."

msgid "retreat_fail"
msgstr ""
"Retraite échouée ! La vitalité gravement endommagée, perte de {years} années de vie."

msgid "retreat_requirements"
msgstr "Aucune restriction ; refroidissement requis"

msgid "retreat_start"
msgstr "{avatar} commence une retraite, durée de la percée inconnue."

msgid "retreat_story_prompt_fail"
msgstr ""
"Ceci concerne une retraite échouée. Décrivez comment le cultivateur a été "
"troublé par les démons intérieurs, l'auto-doute, et finalement a subi un contrecoup lors de la retraite. "
"Aucune description de combat requise."

msgid "retreat_story_prompt_success"
msgstr ""
"Ceci concerne une retraite réussie. Décrivez comment le cultivateur a surmonté "
"la solitude, a compris la Voie Céleste, et a finalement percé le "
"voile de l'esprit en retraite. Aucune description de combat requise."

msgid "retreat_success"
msgstr ""
"Retraite complétée avec succès ! La culture s'est améliorée, la compréhension de "
"la Voie Céleste s'est approfondie."

msgid "{avatar_name} abandoned {item_name}."
msgstr "{avatar_name} a abandonné {item_name}."

msgid ""
"{avatar_name} sold newly obtained {item_name}, gained {price} spirit stones."
msgstr ""
"{avatar_name} a vendu {item_name} fraîchement obtenu, a gagné {price} pierres spirituelles."

msgid "game.sect_update_event"
msgstr "Règlement annuel de {sect_name} : revenu {income} pierres spirituelles, salaires payés {upkeep} pierres spirituelles, solde {net_change} pierres spirituelles."

msgid "War weariness adjusted to {weariness_after} (active wars: {active_war_count}, yearly recovery: 3, previous: {weariness_before})."
msgstr "Lassitude guerrière ajustée à {weariness_after} (guerres actives: {active_war_count}, récupération annuelle: 3, précédente: {weariness_before})."

msgid "game.sect_thinking_event"
msgstr "Réflexion de la secte {sect_name} : {thinking}"

msgid "{winner} won the martial tournament championship and earned {amount} sect contribution for {sect_name}."
msgstr "{winner} a remporté le championnat du tournoi martial et a gagné {amount} contribution de secte pour {sect_name}."

msgid "{teacher_name} taught and guided others at the preaching conference, earning {amount} sect contribution for {sect_name}."
msgstr "{teacher_name} a enseigné et guidé d'autres à la conférence de prédication, gagnant {amount} contribution de secte pour {sect_name}."

msgid "{winner_name} distinguished themselves in sect war and earned {amount} sect contribution for {sect_name}."
msgstr "{winner_name} s'est distingué à la guerre des sectes et a gagné {amount} contribution de secte pour {sect_name}."

msgid "Game automatically saved"
msgstr "Le jeu a été sauvegardé automatiquement"

msgid "{avatar_name} made a name in the cultivation world and came to be known as \"{nickname}\"."
msgstr "{avatar_name} s'est fait un nom dans le monde de la cultivation et est devenu connu sous le nom de « {nickname} »."

msgid "{avatar} self-created technique '{item}'"
msgstr "{avatar} a créé la technique « {item} »."

msgid "{avatar} self-created weapon '{item}'"
msgstr "{avatar} a créé l'arme « {item} »."

msgid "{avatar} self-created auxiliary equipment '{item}'"
msgstr "{avatar} a créé l'équipement auxiliaire « {item} »."

msgid "Equipped newly created {kind} '{item}', sold old equipment '{old_item}' for {refund} spirit stones"
msgstr "Équipé du nouveau {kind} « {item} », ancien équipement « {old_item} » vendu pour {refund} pierres spirituelles"

msgid "Equipped newly created {kind} '{item}'"
msgstr "Équipé du nouveau {kind} « {item} »."


# POI discovery

msgid "{avatar} discovered a grave at {location}: {poi}"
msgstr "{avatar} a découvert une tombe en {location} : {poi}"

msgid "{avatar} discovered a point of interest at {location}: {poi}"
msgstr "{avatar} a découvert un point d’intérêt en {location} : {poi}"
