msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Language: zh-TW\n"

msgid "rest_action_name"
msgstr "休息"

msgid "rest_description"
msgstr "停下來調息休養，恢復生命。龜族休息時會額外獲得少量修為經驗。"

msgid "rest_requirements"
msgstr "沒有特殊要求。"

msgid "eat_mortals_action_name"
msgstr "吃凡人"

msgid "eat_mortals_description"
msgstr "妖族潛入凡人聚居處吞食凡人，將血食與恐懼煉為修為。"

msgid "eat_mortals_requirements"
msgstr "需要是妖族，且位於城市區域；正義陣營通常不會做此事。"

msgid "Dead avatars cannot rest."
msgstr "死者無法休息。"

msgid "{avatar} withdraws into quiet turtle-breathing rest."
msgstr "{avatar}縮入靜處，以龜息之法緩緩休養。"

msgid "{avatar} begins resting."
msgstr "{avatar}開始休息。"

msgid "{avatar} finished resting, recovered {hp} HP and gained {exp} cultivation experience."
msgstr "{avatar}結束休息，恢復了{hp}點生命，並獲得{exp}點修為經驗。"

msgid "{avatar} finished resting and recovered {hp} HP."
msgstr "{avatar}結束休息，恢復了{hp}點生命。"

msgid "Only yao cultivators can eat mortals."
msgstr "只有妖族修士才能吃凡人。"

msgid "Righteous cultivators will not eat mortals."
msgstr "正義陣營的修士不會吃凡人。"

msgid "Can only eat mortals in city areas."
msgstr "只能在城市區域吃凡人。"

msgid "There are no mortals here to eat."
msgstr "這裡沒有可供吞食的凡人。"

msgid "{avatar} stalks the mortal crowds of {city}."
msgstr "{avatar}潛入{city}的人群之中，暗暗尋找血食。"

msgid "{avatar} ate {count} mortals in {city}, refining flesh and fear into {exp} cultivation experience."
msgstr "{avatar}在{city}吃掉了{count}名凡人，將血肉與恐懼煉化為{exp}點修為經驗。"

msgid "{avatar} follows wild instincts to seek spiritual herbs at {location}"
msgstr "{avatar}循著野性本能，在{location}搜尋靈草。"

msgid "{avatar} finished foraging through the wilds, obtained: {materials}"
msgstr "{avatar}在山野間覓食採集完畢，獲得：{materials}"

msgid "{avatar} begins tracking prey by scent and instinct at {location}"
msgstr "{avatar}在{location}憑氣味與本能追蹤獵物。"

msgid "{avatar} finished a primal hunt, obtained: {materials}"
msgstr "{avatar}完成了一場野性的狩獵，獲得：{materials}"

msgid "effect_extra_rest_exp"
msgstr "休息額外修為經驗"

msgid "effect_extra_rest_hp_recovery_rate"
msgstr "休息生命恢復倍率"

msgid "effect_extra_eat_mortals_exp_multiplier"
msgstr "吃凡人修為經驗倍率"

msgid "effect_extra_cross_race_friendliness"
msgstr "跨種族初始好感修正"
