msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Language: zh-TW\n"

msgid "RACE_HUMAN_NAME"
msgstr "人族"

msgid "RACE_HUMAN_DESC"
msgstr "你是一個普通的人類"

msgid "RACE_HUMAN_BEHAVIOR_DESC"
msgstr "人族沒有妖族本能約束，行動主要由性格、目標、宗門、陣營與當前處境決定。"

msgid "RACE_FOX_NAME"
msgstr "狐族"

msgid "RACE_FOX_DESC"
msgstr "狐族天生靈慧，善於察言觀色，容貌多半出眾，常被認為與機緣和人情往來有天然親和。"

msgid "RACE_FOX_BEHAVIOR_DESC"
msgstr "狐族行動優先體現察言觀色、社交試探、交易借勢與機緣嗅覺；普通性格只能修飾手段，不能把狐族寫成直來直往、不經營關係的普通修士。"

msgid "RACE_WOLF_NAME"
msgstr "狼族"

msgid "RACE_WOLF_DESC"
msgstr "狼族血脈強健，重視生存、狩獵與戰鬥，本能敏銳，行動迅捷，常在廝殺中磨礪修為。"

msgid "RACE_WOLF_BEHAVIOR_DESC"
msgstr "狼族行動優先體現生存、狩獵、戰鬥、領地與強弱判斷；普通性格只能改變進攻方式，不能讓狼族長期安坐清談或迴避所有爭鬥。"

msgid "RACE_BIRD_NAME"
msgstr "鳥族"

msgid "RACE_BIRD_DESC"
msgstr "鳥族感知開闊，身法輕靈，天生嚮往遠方，擅長偵察、脫身與探索未知之地。"

msgid "RACE_BIRD_BEHAVIOR_DESC"
msgstr "鳥族行動優先體現遷徙、偵察、遠行、觀察與避險；普通性格只能影響路線與節奏，不能讓鳥族無緣無故久困一地、放棄探索視野。"

msgid "RACE_SNAKE_NAME"
msgstr "蛇族"

msgid "RACE_SNAKE_DESC"
msgstr "蛇族氣息幽微，行事隱忍，擅長潛伏與突襲，常被人族修士忌憚，卻也更能適應陰暗險地。"

msgid "RACE_SNAKE_BEHAVIOR_DESC"
msgstr "蛇族行動優先體現潛伏、隱忍、試探、繞行與突襲；普通性格只能改變是否狠毒，不能把蛇族寫成正面硬碰、熱鬧外放的普通修士。"

msgid "RACE_TURTLE_NAME"
msgstr "龜族"

msgid "RACE_TURTLE_DESC"
msgstr "龜族壽元綿長，體魄穩固，行事緩慢謹慎，最擅長守禦、療養與長久閉關。"

msgid "RACE_TURTLE_BEHAVIOR_DESC"
msgstr "龜族行動優先體現緩慢、守禦、療養、休息與閉關；除非避險、突破、宗門職責、明確目標或資源需求，不應頻繁移動或主動挑起爭端，普通性格不能壓過這種穩守本能。"
