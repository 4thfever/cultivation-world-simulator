"Content-Type: text/plain; charset=UTF-8\n"
"Language: zh-TW\n"

msgid "RACE_HUMAN_NAME"
msgstr "人族"

msgid "RACE_HUMAN_DESC"
msgstr "你是一個普通的人類"

msgid "RACE_FOX_NAME"
msgstr "狐族"

msgid "RACE_FOX_DESC"
msgstr "狐族天生靈慧，善於察言觀色，容貌多半出眾，常被認為與機緣和人情往來有天然親和。"

msgid "RACE_WOLF_NAME"
msgstr "狼族"

msgid "RACE_WOLF_DESC"
msgstr "狼族血脈強健，重視生存、狩獵與戰鬥，本能敏銳，行動迅捷，常在廝殺中磨礪修為。"

msgid "RACE_BIRD_NAME"
msgstr "鳥族"

msgid "RACE_BIRD_DESC"
msgstr "鳥族感知開闊，身法輕靈，天生嚮往遠方，擅長偵察、脫身與探索未知之地。"

msgid "RACE_SNAKE_NAME"
msgstr "蛇族"

msgid "RACE_SNAKE_DESC"
msgstr "蛇族氣息幽微，行事隱忍，擅長潛伏與突襲，常被人族修士忌憚，卻也更能適應陰暗險地。"

msgid "RACE_TURTLE_NAME"
msgstr "龜族"

msgid "RACE_TURTLE_DESC"
msgstr "龜族壽元綿長，體魄穩固，行事緩慢謹慎，最擅長守禦、療養與長久閉關。"
