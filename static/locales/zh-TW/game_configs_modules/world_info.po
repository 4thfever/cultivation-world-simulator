#. world_info.csv: 你有一系列可以執行的動作。要注意動作的效果、限制條件、區域和時間。
msgid "WORLD_INFO_ACTION_DESC"
msgstr "你有一系列可以執行的動作。要注意動作的效果、限制條件、區域和時間。"

msgid "WORLD_INFO_ACTION_NAME"
msgstr "動作"

#. world_info.csv: 动作
msgid "WORLD_INFO_ACTION_TITLE"
msgstr "动作"

#. world_info.csv: 每隔一段不確定的時間會有神祕人組織的拍賣會，或許有好貨出售。
msgid "WORLD_INFO_AUCTION_DESC"
msgstr "每隔一段不確定的時間會有神祕人組織的拍賣會，或許有好貨出售。"

msgid "WORLD_INFO_AUCTION_NAME"
msgstr "拍賣會"

#. world_info.csv: 拍卖会
msgid "WORLD_INFO_AUCTION_TITLE"
msgstr "拍卖会"

#. world_info.csv: 弱肉強食，境界壓制極大，高境界者對低境界者有絕對優勢。若對方死亡，勝者可掠奪敗者財物。
msgid "WORLD_INFO_BATTLE_DESC"
msgstr "弱肉強食，境界壓制極大，高境界者對低境界者有絕對優勢。若對方死亡，勝者可掠奪敗者財物。"

msgid "WORLD_INFO_BATTLE_NAME"
msgstr "戰鬥"

#. world_info.csv: 战斗
msgid "WORLD_INFO_BATTLE_TITLE"
msgstr "战斗"

#. world_info.csv: 修煉可以增加經驗，直到到達突破前的瓶頸。突破是概率事件，突破後會進入下一個境界。
msgid "WORLD_INFO_CULTIVATION_DESC"
msgstr "修行會積累修爲，直至抵達當前階層的瓶頸。突破有成敗之分，成功後會晉入下一層級，失敗則可能付出代價。"

msgid "WORLD_INFO_CULTIVATION_NAME"
msgstr "修煉"

#. world_info.csv: 修炼
msgid "WORLD_INFO_CULTIVATION_TITLE"
msgstr "修炼"

#. world_info.csv: HP降至0以下也會死亡。
msgid "WORLD_INFO_DEATH_DESC"
msgstr "HP降至0以下也會死亡。"

msgid "WORLD_INFO_DEATH_NAME"
msgstr "死亡"

#. world_info.csv: 死亡
msgid "WORLD_INFO_DEATH_TITLE"
msgstr "死亡"

#. world_info.csv: 通過兵器、輔助裝備、丹藥等裝備，可以獲得額外的屬性加成，獲得或小或大的增益。擁有好的裝備或者服...
msgid "WORLD_INFO_EQUIPMENT_AND_ELIXIR_DESC"
msgstr "兵器、輔助裝備與丹藥能帶來額外加成。高品階裝備與合適丹藥往往能顯著提升修士的生存與爭鬥能力。"

msgid "WORLD_INFO_EQUIPMENT_AND_ELIXIR_NAME"
msgstr "裝備與丹藥"

#. world_info.csv: 装备与丹药
msgid "WORLD_INFO_EQUIPMENT_AND_ELIXIR_TITLE"
msgstr "装备与丹药"

#. world_info.csv: 這是一個諸多修士競相修行、紛爭四起的修仙世界。
msgid "WORLD_INFO_INTRO_DESC"
msgstr "這是一個諸多修士競相修行、紛爭四起的修仙世界。"

msgid "WORLD_INFO_INTRO_NAME"
msgstr "簡介"

#. world_info.csv: 简介
msgid "WORLD_INFO_INTRO_TITLE"
msgstr "简介"

#. world_info.csv: 若當前年齡達到最大壽元，會立刻死亡。突破境界可以增加最大壽元，突破失敗也可能折損壽元。
msgid "WORLD_INFO_LIFESPAN_DESC"
msgstr "每個角色都有壽元上限。壽元耗盡時會死亡；突破境界通常能延長壽元，突破失敗也可能折損壽元。"

msgid "WORLD_INFO_LIFESPAN_NAME"
msgstr "壽元"

#. world_info.csv: 寿元
msgid "WORLD_INFO_LIFESPAN_TITLE"
msgstr "寿元"

#. world_info.csv: 道、佛、儒等根本理念，決定門派的根腳與修行起源。
msgid "WORLD_INFO_ORTHODOXY_DESC"
msgstr "不同的道統有不同的修行方法。道家吐納，武家鍛體，佛家禪定，儒家教化民衆。"

#. world_info.csv: 道統
msgid "WORLD_INFO_ORTHODOXY_NAME"
msgstr "道統"

#. world_info.csv: 道統
msgid "WORLD_INFO_ORTHODOXY_TITLE"
msgstr "道統"

#. world_info.csv: 修仙的境界從弱到強：練氣、築基、金丹、元嬰。每個境界分前期、中期、後期。境界間差距很大。
msgid "WORLD_INFO_REALM_DESC"
msgstr "世界底層境界從弱到強爲練氣、築基、金丹、元嬰，每境分前期、中期、後期。不同道統可有別名，但規則計算仍以這套標準序列爲準。"

msgid "WORLD_INFO_REALM_NAME"
msgstr "境界"

#. world_info.csv: 境界
msgid "WORLD_INFO_REALM_TITLE"
msgstr "境界"

#. world_info.csv: 不同區域有不同效果，在適當的區域做適當的事情事半功倍。
msgid "WORLD_INFO_REGION_DESC"
msgstr "不同區域有不同效果，在適當的區域做適當的事情事半功倍。"

msgid "WORLD_INFO_REGION_NAME"
msgstr "區域"

#. world_info.csv: 区域
msgid "WORLD_INFO_REGION_TITLE"
msgstr "区域"

#. world_info.csv: 靈根由五行元素（金、木、水、火、土）組成，分爲單靈根、雙靈根和天靈根。五行相剋：金克木，木克土...
msgid "WORLD_INFO_ROOT_DESC"
msgstr ""
"靈根由五行元素（金、木、水、火、土）組成，分爲單靈根、雙靈根和天靈根。五行相剋：金克木，木克土，土克水，水克火，火克金。天靈根包含全部五行元素且突破時有額外加成。在與自身靈根屬性匹配的區域修煉效率最高。"

msgid "WORLD_INFO_ROOT_NAME"
msgstr "靈根"

#. world_info.csv: 灵根
msgid "WORLD_INFO_ROOT_TITLE"
msgstr "灵根"

#. world_info.csv: 每隔數年會有祕境開啓。進入祕境可能遭遇兇險，也可能獲得高階法寶和功法。
msgid "WORLD_INFO_SECRET_REALM_DESC"
msgstr "每隔數年會有祕境開啓。進入祕境可能遭遇兇險，也可能獲得高階法寶和功法。"

msgid "WORLD_INFO_SECRET_REALM_NAME"
msgstr "祕境"

#. world_info.csv: 秘境
msgid "WORLD_INFO_SECRET_REALM_TITLE"
msgstr "祕境"

#. world_info.csv: 修士的庇護所。加入宗門可習得獨門功法、獲同門庇護；散修自由但資源匱乏。
msgid "WORLD_INFO_SECT_DESC"
msgstr "修士的庇護所。加入宗門可習得獨門功法、獲同門庇護；散修自由但資源匱乏。"

msgid "WORLD_INFO_SECT_NAME"
msgstr "宗門"

#. world_info.csv: 宗门
msgid "WORLD_INFO_SECT_TITLE"
msgstr "宗门"

#. world_info.csv: 在城市區域可以購買練氣級別丹藥、兵器。購買丹藥後會立刻服用強化自身。購買兵器可以幫自己切換兵器...
msgid "WORLD_INFO_SHOPPING_DESC"
msgstr "在城市區域可以購買練氣品階的丹藥與兵器。購買丹藥後會立刻服用以強化自身；購買兵器可切換爲更順手的兵器類型。"

msgid "WORLD_INFO_SHOPPING_NAME"
msgstr "購物"

#. world_info.csv: 购物
msgid "WORLD_INFO_SHOPPING_TITLE"
msgstr "购物"

#. world_info.csv: 修仙界的通用貨幣。可用於購買法寶丹藥，通過採集、交易或掠奪獲取。
msgid "WORLD_INFO_SPIRIT_STONE_DESC"
msgstr "修仙界的通用貨幣。可用於購買法寶丹藥，通過採集、交易或掠奪獲取。"

msgid "WORLD_INFO_SPIRIT_STONE_NAME"
msgstr "靈石"

#. world_info.csv: 灵石
msgid "WORLD_INFO_SPIRIT_STONE_TITLE"
msgstr "灵石"

#. world_info.csv: 世界每隔数年会有一次天象变动（如灵气潮汐），影响角色能力。
msgid "WORLD_INFO_WORLD_QI_DESC"
msgstr "世界每隔數年會有一次天象變動（如靈氣潮汐），影響角色能力。"

msgid "WORLD_INFO_WORLD_QI_NAME"
msgstr "天地靈機"

#. world_info.csv: 天地灵机
msgid "WORLD_INFO_WORLD_QI_TITLE"
msgstr "天地灵机"

#. world_info.csv: 修仙界设有天地人三榜及宗门榜。天榜收录元婴期强者，地榜收录金丹期强者，人榜收录筑基期强者，宗门榜按宗门总实力排名。
msgid "WORLD_INFO_RANKING_DESC"
msgstr "修仙界設有天地人三榜及宗門榜。天地人三榜按等價標準境界劃分：天榜收錄元嬰層級強者，地榜收錄金丹層級強者，人榜收錄築基層級強者；宗門榜按宗門總實力排名。"

#. world_info.csv: 排行榜
msgid "WORLD_INFO_RANKING_NAME"
msgstr "排行榜"

#. world_info.csv: 排行榜
msgid "WORLD_INFO_RANKING_TITLE"
msgstr "排行榜"

#. world_info.csv: 凡人王朝统御天下，维持凡俗秩序与疆域。皇帝寿元与普通凡人无异，驾崩后会有新帝继位。
msgid "WORLD_INFO_DYNASTY_DESC"
msgstr "凡人王朝統御天下，維持凡俗秩序與疆域。皇帝壽元與普通凡人無異，駕崩後會有新帝繼位。"

#. world_info.csv: 王朝
msgid "WORLD_INFO_DYNASTY_NAME"
msgstr "王朝"

#. world_info.csv: 王朝
msgid "WORLD_INFO_DYNASTY_TITLE"
msgstr "王朝"

#. world_info.csv: 修士可为朝廷理政，积累朝廷威望并领取俸禄。威望足够可升官，官职越高，俸禄与气运越多；久不理政，威望会逐渐下滑。
msgid "WORLD_INFO_OFFICIAL_DESC"
msgstr "修士可為朝廷理政，積累朝廷威望並領取俸祿。威望足夠可升官，官職越高，俸祿與氣運越多；久不理政，威望會逐漸下滑。"

#. world_info.csv: 官职
msgid "WORLD_INFO_OFFICIAL_NAME"
msgstr "官職"

#. world_info.csv: 官职
msgid "WORLD_INFO_OFFICIAL_TITLE"
msgstr "官職"

#. world_info.csv: 同一修行阶层在不同体系中有各自名目。
msgid "WORLD_INFO_CULTIVATION_ALIAS_DESC"
msgstr "同一修行階層在不同體系中有各自名目：道家與散修爲練氣、築基、金丹、元嬰；武道爲淬體、易筋、宗師、武聖；儒道爲養氣、明理、立命、大儒；佛道爲沙彌、比丘、羅漢、菩薩；妖族爲開靈、化形、妖丹、妖王。它們彼此對應的是同一套底層境界序列，只改變敘事與介面稱謂，不改變突破、戰力、壽元、物品品階等規則。"

#. world_info.csv: 阶层别名
msgid "WORLD_INFO_CULTIVATION_ALIAS_NAME"
msgstr "階層別名"

#. world_info.csv: 阶层别名
msgid "WORLD_INFO_CULTIVATION_ALIAS_TITLE"
msgstr "階層別名"

#. world_info.csv: 蛊术需要修士持有蛊具并拥有下蛊能力，才能对可观测目标施加蛊。
msgid "WORLD_INFO_GU_DESC"
msgstr "蠱術需要修士持有蠱具並擁有下蠱能力，才能對可觀測目標施加蠱。不同蠱有不同發作方式：潛心蠱會潛移默化影響關係，噬血蠱會週期性損傷生命，蝕元蠱與亂心蠱會侵擾修為。下蠱有成功率，受蠱具、施術者加成與目標抗蠱能力影響；失敗時可能被目標察覺並損害關係。"

#. world_info.csv: 蛊
msgid "WORLD_INFO_GU_NAME"
msgstr "蠱"

#. world_info.csv: 蛊
msgid "WORLD_INFO_GU_TITLE"
msgstr "蠱"

#. world_info.csv: 阵法需要修士持有阵盘并拥有布阵能力，才能在当前区域布置限时区域效果。
msgid "WORLD_INFO_FORMATION_DESC"
msgstr "陣法需要修士持有陣盤並擁有布陣能力，才能在當前區域布置限時區域效果。不同陣法適合不同區域：修行地與宗門可布聚靈、守山、明心等陣；城市可布療癒陣；礦脈、藥田、獸域可布對應的尋脈、生木、驅獸陣。陣法會消耗靈石，並在持續時間結束後失效。"

#. world_info.csv: 阵法
msgid "WORLD_INFO_FORMATION_NAME"
msgstr "陣法"

#. world_info.csv: 阵法
msgid "WORLD_INFO_FORMATION_TITLE"
msgstr "陣法"

#. world_info.csv: 機緣
msgid "WORLD_INFO_OPPORTUNITY_DESC"
msgstr "修士偶有福至心靈，感應到某人或某地與自身緣法相牽。若循感應而去，或得寶物與助益，或空手而返，亦可能遭逢凶險；若遲遲未尋，機緣也會自行散去。"

#. world_info.csv: 機緣
msgid "WORLD_INFO_OPPORTUNITY_NAME"
msgstr "機緣"

#. world_info.csv: 機緣
msgid "WORLD_INFO_OPPORTUNITY_TITLE"
msgstr "機緣"
