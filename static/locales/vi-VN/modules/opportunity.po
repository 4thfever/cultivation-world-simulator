msgid "nearby"
msgstr "gần đây"

msgid "northeast"
msgstr "đông bắc"

msgid "northwest"
msgstr "tây bắc"

msgid "southeast"
msgstr "đông nam"

msgid "southwest"
msgstr "tây nam"

msgid "old city"
msgstr "cổ thành"

msgid "sect territory"
msgstr "đất tông môn"

msgid "cave dwelling"
msgstr "động phủ"

msgid "wilderness place"
msgstr "nơi hoang vắng"

msgid "unknown place"
msgstr "nơi chưa rõ"

msgid "unknown realm"
msgstr "cảnh giới chưa rõ"

msgid "{realm} cultivator"
msgstr "tu sĩ {realm}"

msgid "{realm} {weapon_type} cultivator"
msgstr "tu sĩ {realm} dùng {weapon_type}"

msgid "{realm} sect cultivator"
msgstr "tu sĩ tông môn {realm}"

msgid ""
"{avatar_name} felt a stir of fate, sensing a thread of opportunity tied to a "
"{region_hint} in the {direction}."
msgstr ""
"{avatar_name} chợt cảm thấy thiên cơ lay động, mơ hồ nhận ra một mối cơ duyên "
"gắn với một {region_hint} ở hướng {direction}."

msgid ""
"{avatar_name} felt a stir of fate, sensing a thread of opportunity tied to a "
"{target_hint} in the {direction}."
msgstr ""
"{avatar_name} chợt cảm thấy thiên cơ lay động, mơ hồ nhận ra một mối cơ duyên "
"gắn với một {target_hint} ở hướng {direction}."

msgid "{avatar_name}'s opportunity sense gradually faded away."
msgstr "Mối cảm ứng cơ duyên trong lòng {avatar_name} dần tan biến."

msgid "{avatar_name}'s opportunity sense suddenly broke, leaving nowhere to seek."
msgstr "Mối cảm ứng cơ duyên trong lòng {avatar_name} đột ngột đứt đoạn, không còn nơi để tìm."

msgid ""
"{avatar_name} followed the opportunity and found an ancient treasure: "
"{item_name}."
msgstr ""
"{avatar_name} lần theo cơ duyên và tìm thấy di vật cổ tu: {item_name}."

msgid ""
"{avatar_name} followed the opportunity and obtained {item_name}. "
"{exchange_text}"
msgstr ""
"{avatar_name} lần theo cơ duyên và nhận được {item_name}. {exchange_text}"

msgid "{avatar_name} followed the opportunity and gained a boon: {boon_title}."
msgstr "{avatar_name} lần theo cơ duyên và nhận được trợ ích: {boon_title}."

msgid "{avatar_name} followed the opportunity, but the spiritual trace faded away."
msgstr "{avatar_name} lần theo cơ duyên, nhưng dấu vết linh cơ đã tan biến."

msgid ""
"{avatar_name} followed the feeling, but only found the spiritual trace "
"already gone."
msgstr ""
"{avatar_name} lần theo cảm ứng, nhưng chỉ thấy dấu vết linh cơ đã tan biến."

msgid ""
"{avatar_name} followed the opportunity, but suffered backlash and was injured "
"for {damage} HP."
msgstr ""
"{avatar_name} lần theo cơ duyên, nhưng bị phản phệ và mất {damage} HP."

msgid "{avatar_name} followed the opportunity, but suffered backlash and perished."
msgstr "{avatar_name} lần theo cơ duyên, nhưng bị phản phệ chí mạng và thân tử đạo tiêu."

msgid "opportunity_boon"
msgstr "Trợ ích cơ duyên"

msgid "opportunity_story_prompt"
msgstr "Hãy viết một đoạn truyện tiên hiệp ngắn xoay quanh kết quả cơ duyên này, nhấn mạnh thiên cơ dẫn dắt, tình cảnh hiện tại của nhân vật và chính kết quả đã xảy ra. Không viết lại các sự thật đã được xác lập."

msgid "{years} years and {months} months"
msgstr "{years} năm {months} tháng"

msgid "{years} years"
msgstr "{years} năm"

msgid "{months} months"
msgstr "{months} tháng"

msgid "Opportunity sense: {hint} This sense may last about {remaining}."
msgstr "Cảm ứng cơ duyên: {hint} Cảm ứng này có thể còn kéo dài khoảng {remaining}."

msgid "effect_extra_opportunity_probability"
msgstr "Xác suất cơ duyên +{value}"

msgid "effect_source_opportunity"
msgstr "Cơ duyên"
