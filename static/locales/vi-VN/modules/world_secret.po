msgid "{avatar} heard a hidden clue in the market rumors of {location}: {fragment}"
msgstr "{avatar} nghe được một manh mối bí ẩn trong lời đồn nơi phường thị ở {location}: {fragment}"

msgid "{avatar} glimpsed a corner of the truth through a mysterious insight: {fragment}"
msgstr "{avatar} thoáng nhìn thấy một góc chân tướng trong cảm ngộ huyền bí: {fragment}"

msgid "{avatar} noticed an unusual clue at {location}: {fragment}"
msgstr "{avatar} phát hiện một manh mối khác thường tại {location}: {fragment}"

msgid "{avatar} connected scattered clues and finally learned a world secret capable of shaking this realm's foundations."
msgstr "{avatar} nối liền các manh mối rời rạc và cuối cùng biết được một bí mật thế giới đủ sức lay động nền móng cõi này."

msgid "{avatar} has pieced together scattered clues and learned a world secret capable of shaking this realm's foundations. If revealed, the secret will become known to all under heaven; if kept silent, only {avatar} will bear it. Complete secret: {secret}"
msgstr "{avatar} đã ghép các manh mối rời rạc và biết được một bí mật thế giới đủ sức lay động nền móng cõi này. Nếu công khai, bí mật sẽ thành nhận thức chung trong thiên hạ; nếu im lặng, chỉ {avatar} tự mình gánh chịu. Bí mật đầy đủ: {secret}"

msgid "Reveal the world secret?"
msgstr "Công khai bí mật thế giới?"

msgid "You have learned a secret capable of shaking the world's foundations. Will you tell all under heaven, or remain silent alone?"
msgstr "Bạn đã biết một bí mật đủ sức lay động nền móng thế giới. Bạn sẽ nói cho thiên hạ, hay một mình im lặng?"

msgid "Tell everyone"
msgstr "Nói cho mọi người"

msgid "Reveal the complete secret so all cultivators under heaven know this realm's truth."
msgstr "Công bố bí mật đầy đủ để tu sĩ trong thiên hạ đều biết chân tướng cõi này."

msgid "Bear it silently"
msgstr "Âm thầm gánh chịu"

msgid "Do not spread it; bear this truth alone."
msgstr "Không chủ động truyền ra, chỉ một mình gánh chịu chân tướng này."

msgid "{avatar} revealed a world secret to all: '{title}'. From now on, cultivators under heaven know this realm's truth."
msgstr "{avatar} công khai một bí mật thế giới: “{title}”. Từ nay, tu sĩ trong thiên hạ đều biết chân tướng cõi này."

msgid "{avatar} chose silence after learning the truth, pressing this secret deep into the heart."
msgstr "{avatar} sau khi biết chân tướng đã chọn im lặng, chôn sâu bí mật này trong lòng."
