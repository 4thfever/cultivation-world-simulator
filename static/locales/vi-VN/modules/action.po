msgid "move_to_avatar_requirements"
msgstr "Không hạn chế"

# Action: MoveToDirection
msgid "move_to_direction_action_name"
msgstr "Di Chuyển Thăm Dò"

msgid "move_to_direction_description"
msgstr "Thăm dò khu vực chưa biết theo một phương hướng"

msgid "move_to_direction_requirements"
msgstr "Không hạn chế"

# Action: MoveToRegion
msgid "move_to_region_action_name"
msgstr "Di Chuyển Tới Khu Vực"

msgid "move_to_region_description"
msgstr "Di chuyển tới một khu vực cụ thể"

msgid "move_to_region_requirements"
msgstr "Không hạn chế"

msgid "neutral"
msgstr "Trung Lập"

# Action: NurtureWeapon
msgid "nurture_weapon_action_name"
msgstr "Ôn Dưỡng Binh Khí"

msgid "nurture_weapon_description"
msgstr "Ôn dưỡng binh khí để tăng độ thuần thục binh khí"

msgid "nurture_weapon_requirements"
msgstr "Không hạn chế"

# Action: Play
msgid "play_action_name"
msgstr "Giải Khuây"

msgid "play_description"
msgstr "Giải khuây để thư giãn thân tâm"

msgid "play_requirements"
msgstr "Mục tiêu ở trong phạm vi tương tác"

# Action: PlunderPeople
msgid "plunder_people_action_name"
msgstr "Vơ Vét Dân Chúng"

msgid "plunder_people_description"
msgstr "Vơ vét dân chúng trong thành để có được một ít linh thạch"

msgid "plunder_people_requirements"
msgstr "Chỉ trong khu vực thành thị, và trận doanh của nhân vật phải là 'tà'"

# Action: Refine
msgid "refine_action_name"
msgstr "Luyện Đan"

msgid "refine_description"
msgstr ""
"Tiêu hao vật liệu để thử luyện chế đan dược (tham số target_realm: "
"QI_REFINEMENT, FOUNDATION_ESTABLISHMENT, CORE_FORMATION, NASCENT_SOUL)"

msgid "refine_requirements"
msgstr "Sở hữu 3 vật liệu cùng cảnh giới"

# Action: Respire
msgid "respire_action_name"
msgstr "Thổ Nạp"

msgid "respire_description"
msgstr ""
"Thuận theo Thiên Đạo, thổ nạp linh khí. Mật độ linh khí càng cao thì hiệu "
"quả càng tốt."

msgid "respire_requirements"
msgstr "Yêu cầu đạo thống Đạo môn hoặc thân phận tán tu"

msgid "respire_sect_hq_members_only"
msgstr "Chỉ đệ tử của tông môn này mới có thể thổ nạp tại tổng bộ của họ."

msgid "respire_efficiency_sect_hq"
msgstr "Tiến cảnh ổn định (tổng bộ tông môn)"

# Action: SelfHeal
msgid "self_heal_action_name"
msgstr "Tự Trị Thương"

msgid "self_heal_description"
msgstr ""
"Vận công chữa thương; có thể hoàn toàn hồi phục tại tổng bộ tông môn"

msgid "self_heal_requirements"
msgstr "HP hiện tại chưa đầy"

# Action: Sell
msgid "sell_action_name"
msgstr "Bán"

msgid "sell_description"
msgstr ""
"Bán toàn bộ vật phẩm thuộc một loại nhất định đang sở hữu, hoặc trang bị "
"hiện tại trong thành trấn"

msgid "sell_requirements"
msgstr "Đang ở trong thành trấn và sở hữu vật phẩm/trang bị có thể bán"

msgid "slow progress (essence mismatch)"
msgstr "Tiến cảnh chậm (linh khí không tương hợp)"

msgid "slow progress (sparse essence)"
msgstr "Tiến cảnh chậm (linh khí thưa thớt)"

msgid "succeeded"
msgstr "thành công"

# Action: Temper
msgid "temper_action_name"
msgstr "Tôi Luyện"

msgid "temper_description"
msgstr ""
"Dùng cách rèn luyện cực hạn để tôi luyện nhục thân khí lực, không cầu ngoại "
"vật, không tiêu hao linh khí."

msgid "temper_requirements"
msgstr "Yêu cầu đạo thống Võ đạo"

msgid "wilderness"
msgstr "hoang giao dã ngoại"

msgid ""
"{attacker} initiates battle against {target} (Power: {attacker} {att_power} "
"vs {target} {def_power})"
msgstr ""
"{attacker} phát khởi chiến đấu với {target} (Chiến lực: {attacker} {att_power} "
"vs {target} {def_power})"

msgid "{avatar} assassinated successfully! {target} fell without any defense."
msgstr ""
"{avatar} ám sát thành công! {target} ngã xuống khi chưa kịp phòng bị."

msgid "{avatar} attempted to move but target is invalid"
msgstr "{avatar} thử di chuyển nhưng mục tiêu không hợp lệ"

msgid "{avatar} begins Zen Meditation."
msgstr "{avatar} bắt đầu tọa thiền nhập định."

msgid "{avatar} begins attempting breakthrough"
msgstr "{avatar} bắt đầu thử đột phá cảnh giới"

msgid "{avatar} begins attempting to cast {realm}-tier treasure"
msgstr "{avatar} bắt đầu thử đúc tạo pháp bảo bậc {realm}"

msgid "{avatar} begins attempting to refine {realm}-tier elixir"
msgstr "{avatar} bắt đầu thử luyện chế đan dược bậc {realm}"

msgid "{avatar} begins devouring people in town"
msgstr "{avatar} bắt đầu thôn phệ sinh linh trong thành"

msgid "{avatar} begins educating people in {city}."
msgstr "{avatar} bắt đầu giáo hóa bách tính tại {city}."

msgid "{avatar} begins helping people in town"
msgstr "{avatar} bắt đầu cứu tế bách tính trong thành"

msgid "{avatar} begins leisure activities"
msgstr "{avatar} bắt đầu giải khuây thư giãn"

msgid "{avatar} begins plundering people in town"
msgstr "{avatar} bắt đầu vơ vét dân chúng trong thành"

msgid "{avatar} begins tempering body strength"
msgstr "{avatar} bắt đầu tôi luyện khí lực nhục thân"

msgid "{avatar} completed meditation with a peaceful mind."
msgstr "{avatar} hoàn tất thiền định, tâm cảnh an hòa."

msgid ""
"{avatar} failed to cast {realm}-tier treasure, all materials turned to ash"
msgstr ""
"{avatar} đúc tạo pháp bảo bậc {realm} thất bại, toàn bộ vật liệu hóa thành tro bụi"

msgid ""
"{avatar} failed to refine {realm}-tier elixir, all materials turned to ash"
msgstr ""
"{avatar} luyện chế đan dược bậc {realm} thất bại, toàn bộ vật liệu hóa thành tro bụi"

msgid "{avatar} failed to tame spirit beast"
msgstr "{avatar} thuần phục linh thú thất bại"

msgid "{avatar} finished educating people. Merit accumulated (+{exp})."
msgstr "{avatar} hoàn tất giáo hóa. Công đức tích lũy (+{exp})."

msgid ""
"{avatar} finished nurturing {weapon}, proficiency increased to "
"{proficiency}%"
msgstr ""
"{avatar} hoàn tất ôn dưỡng {weapon}, độ thuần thục tăng lên {proficiency}%"

msgid "{avatar} finished {action}."
msgstr "{avatar} đã hoàn tất {action}."

msgid ""
"{avatar} had an epiphany during meditation! Cultivation increased "
"significantly (+{exp})."
msgstr ""
"{avatar} đã đốn ngộ trong lúc thiền định! Tu vi tăng mạnh (+{exp})."

msgid "{avatar} healing completed (recovered {amount} HP, current HP {hp})"
msgstr "{avatar} chữa thương hoàn tất (hồi phục {amount} HP, HP hiện tại {hp})"

msgid "{avatar} lurks in the shadows, attempting to assassinate {target}..."
msgstr "{avatar} ẩn nấp trong bóng tối, đang mưu toan ám sát {target}..."

msgid ""
"{avatar} nurturing {old_weapon}, the weapon's spirituality greatly "
"increased, evolved into {new_weapon}!"
msgstr ""
"{avatar} trong lúc ôn dưỡng {old_weapon}, linh tính của binh khí tăng vọt, "
"thăng hoa thành {new_weapon}!"

msgid "{avatar} sold {item} in town"
msgstr "{avatar} đã bán {item} trong thành trấn"

msgid "{avatar} successfully cast {realm}-tier {label} '{item}'"
msgstr "{avatar} đã thành công đúc tạo {label} bậc {realm} '{item}'"

msgid "{avatar} successfully refined {realm}-tier elixir '{item}'"
msgstr "{avatar} đã thành công luyện chế đan dược bậc {realm} '{item}'"

msgid ""
"{avatar} successfully tamed spirit beast, {realm} realm {beast} became their"
" spirit beast"
msgstr ""
"{avatar} thuần phục linh thú thành công, {beast} cảnh giới {realm} đã trở "
"thành linh thú của họ"

msgid "{initiator} invites {target} for dual cultivation"
msgstr "{initiator} mời {target} cùng tiến hành song tu"

msgid "{root_name} ({elements})"
msgstr "{root_name} ({elements})"

msgid "An anonymous passerby (extra)"
msgstr "Một người qua đường vô danh"

msgid "Current world celestial phenomenon: {name}"
msgstr "Thiên tượng thế giới hiện tại: {name}"

msgid "plant_action_name"
msgstr "Trồng Trọt"

msgid "plant_description"
msgstr ""
