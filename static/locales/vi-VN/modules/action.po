msgid ""
"Evil alignment follows the principles of survival of the fittest, "
"prioritizing self-interest above all, disdaining rules, and venerating power"
" and fear. Acts ruthlessly, often resorting to murder and plunder."
msgstr ""
"Trận doanh tà ác tôn thờ đạo lý mạnh được yếu thua, đặt lợi ích bản thân lên "
"trên hết, khinh thường quy tắc, tôn sùng quyền lực và nỗi sợ. Hành sự ngoan "
"độc, thường có những việc như sát nhân đoạt bảo."

msgid ""
"Neutral alignment follows the principles of going with the flow, seeking "
"benefit and avoiding harm, valuing self-cultivation and balance, and not "
"easily taking sides."
msgstr ""
"Trận doanh trung lập lấy thuận thế mà làm, tránh hại cầu lợi, coi trọng tự "
"độ cùng cân bằng, không dễ nghiêng về phe nào."

msgid ""
"Righteous alignment follows the principles of helping the weak, maintaining "
"order, and vanquishing evil."
msgstr ""
"Trận doanh chính đạo lấy việc phù trợ kẻ yếu, duy trì trật tự và trừ ma vệ đạo làm "
"chuẩn tắc."

# Action Short Names (for legal_actions)
msgid "action_dualcultivation_short_name"
msgstr "Song Tu"

msgid "action_educate_short_name"
msgstr "Giáo Hóa"

msgid "action_meditate_short_name"
msgstr "Thiền Định"

# Action: Play Extended
msgid "action_reading"
msgstr "Đọc Sách"

msgid "action_reading_desc"
msgstr "Nghiên đọc cổ tịch để mở mang kiến thức."

msgid "action_respire_short_name"
msgstr "Thổ Nạp"

msgid "action_tea_party"
msgstr "Trà Hội"

msgid "action_tea_party_desc"
msgstr "Cùng bằng hữu thưởng trà."

msgid "action_tea_party_story_prompt"
msgstr "Hai người đang mở một trà hội thanh nhã."

msgid "action_tea_tasting"
msgstr "Phẩm Trà"

msgid "action_tea_tasting_desc"
msgstr "Nếm trà ngon, dưỡng tâm tĩnh khí."

msgid "action_temper_short_name"
msgstr "Tôi Luyện"

msgid "action_traveling"
msgstr "Du Lịch"

msgid "action_traveling_desc"
msgstr "Du lịch tứ phương để cảm ngộ thiên địa."

msgid "action_zither_playing"
msgstr "Phủ Cầm"

msgid "action_zither_playing_desc"
msgstr "Phủ cầm tấu nhạc, bồi dưỡng tính tình."

# Action: Assassinate
msgid "assassinate_action_name"
msgstr "Ám Sát"

msgid "assassinate_description"
msgstr "Ám sát mục tiêu; nếu thất bại sẽ chuyển thành chiến đấu"

msgid "assassinate_requirements"
msgstr "Không hạn chế; cần thời gian hồi"

msgid "assassinate_story_prompt_fail"
msgstr ""
"Đây là câu chuyện về một lần ám sát thất bại. Thích khách mưu toan giết mục "
"tiêu, nhưng bị đối phương nhạy bén phát giác. Sau đó đôi bên bộc phát xung "
"đột chính diện dữ dội. Không được nhắc tới chỉ số HP cụ thể."

msgid "assassinate_story_prompt_success"
msgstr ""
"Đây là câu chuyện về một lần ám sát thành công. Không cần miêu tả quá trình "
"giao chiến, hãy tập trung vào cách thích khách ẩn nấp, áp sát và tung ra "
"một kích trí mạng lặng lẽ. Mục tiêu còn chưa kịp phản ứng đã phải vẫn lạc."

# Action: Attack
msgid "attack_action_name"
msgstr "Phát Khởi Chiến Đấu"

msgid "attack_description"
msgstr "Tấn công mục tiêu và tiến vào giao chiến"

msgid "attack_requirements"
msgstr "Không hạn chế"

msgid "attack_story_prompt"
msgstr ""
"Không được nhắc tới HP, điểm thương hại hay bất cứ biểu đạt số liệu cụ thể "
"nào. Trận chiến phải thể hiện được công pháp, cảnh giới, trang bị của đôi "
"bên v.v."

msgid "bought"
msgstr "đã mua"

msgid "bought and consumed"
msgstr "đã mua rồi dùng"

msgid "bought and equipped"
msgstr "đã mua rồi trang bị"

msgid "breakthrough probability increased by {val:.1%}"
msgstr "Xác suất đột phá tăng thêm {val:.1%}."

# Action: Breakthrough
msgid "breakthrough_action_name"
msgstr "Đột Phá"

msgid "breakthrough_description"
msgstr ""
"Thử đột phá cảnh giới (thành công sẽ tăng thọ nguyên tối đa, thất bại sẽ làm "
"giảm; cảnh giới càng cao thì xác suất thành công càng thấp)"

msgid "breakthrough_requirements"
msgstr "Nhân vật phải đang ở bình cảnh; không thể liên tục chấp hành"

# Action: Buy
msgid "buy_action_name"
msgstr "Mua"

msgid "buy_description"
msgstr "Mua vật phẩm/trang bị/đan dược trong thành trấn"

msgid "buy_requirements"
msgstr "Đang ở trong thành và có đủ tiền"

# Action: Cast
msgid "cast_action_name"
msgstr "Đúc Tạo"

msgid "cast_description"
msgstr ""
"Tiêu hao vật liệu để thử đúc tạo pháp bảo (tham số target_realm: "
"QI_REFINEMENT, FOUNDATION_ESTABLISHMENT, CORE_FORMATION, NASCENT_SOUL)"

msgid "cast_requirements"
msgstr "Sở hữu 5 vật liệu cùng cảnh giới"

# Action: Catch
msgid "catch_action_name"
msgstr "Ngự Thú"

msgid "catch_description"
msgstr ""
"Thử thuần phục một linh thú để trở thành linh thú của bản thân. Chỉ có thể "
"sở hữu một linh thú, nhưng có thể dùng linh thú cao cấp thay thế loại thấp "
"cấp"

msgid "catch_requirements"
msgstr ""
"Chỉ dành cho Bách Thú Tông; ở trong khu vực thường có động vật; cảnh giới "
"động vật mục tiêu không được cao hơn nhân vật"

# Action: DevourPeople
msgid "devour_people_action_name"
msgstr "Thôn Phệ Sinh Linh"

msgid "devour_people_description"
msgstr "Thôn phệ sinh linh để tăng mạnh chiến lực"

msgid "devour_people_requirements"
msgstr "Sở hữu Vạn Hồn Phiên"

# Action: DualCultivation
msgid "dual_cultivation_action_name"
msgstr "Song Tu"

msgid "dual_cultivation_description"
msgstr "Lấy tình nhập đạo để song tu, đối phương có thể chấp nhận hoặc từ chối"

msgid "dual_cultivation_requirements"
msgstr "Mục tiêu ở trong phạm vi tương tác; không thể liên tục chấp hành"

msgid "dual_cultivation_story_prompt"
msgstr ""
"Hai vị tu sĩ nảy sinh tình ý trong quá trình song tu. Hãy dùng bút pháp hàm "
"súc, thanh nhã để miêu tả một đoạn trải nghiệm song tu mờ ám mà không lộ "
"liễu, thể hiện tính cách, chênh lệch cảnh giới và những khoảnh khắc tình ái "
"ngọt ngào của đôi bên. Không được đề cập tới số trị kinh nghiệm."

# Action: Educate
msgid "educate_action_name"
msgstr "Giáo Hóa"

msgid "educate_description"
msgstr ""
"Con đường tu luyện của Nho môn. Giáo hóa thế nhân trong thành để tích lũy "
"công đức và khí vận."

msgid "educate_requirements"
msgstr "Yêu cầu đạo thống Nho gia và đang ở trong thành"

# Action: Escape
msgid "escape_action_name"
msgstr "Bỏ Trốn"

msgid "escape_description"
msgstr "Thoát khỏi đối thủ (phán định dựa trên xác suất thành công)"

msgid "escape_requirements"
msgstr "Không hạn chế"

msgid "evil"
msgstr "Tà"

msgid "excellent progress"
msgstr "tiến cảnh khá tốt"

msgid "failed"
msgstr "thất bại"

msgid "gained {val} cultivation"
msgstr "Tăng {val} điểm tu vi."

# Action: Harvest
msgid "harvest_action_name"
msgstr "Thu Thập"

msgid "harvest_description"
msgstr "Thu thập thực vật trong khu vực hiện tại để nhận vật liệu thực vật"

msgid "harvest_requirements"
msgstr ""
"Đang ở khu vực thường có thực vật, và cảnh giới của avatar phải lớn hơn hoặc "
"bằng cảnh giới của thực vật"

# Action: HelpPeople
msgid "help_people_action_name"
msgstr "Cứu Tế Bách Tính"

msgid "help_people_description"
msgstr "Cứu tế bách tính trong thành, tiêu hao một lượng nhỏ linh thạch"

msgid "help_people_requirements"
msgstr "Chỉ trong khu vực thành thị, và có đủ linh thạch"

# Action: Hunt
msgid "hunt_action_name"
msgstr "Săn Bắn"

msgid "hunt_description"
msgstr "Săn động vật trong khu vực hiện tại để nhận vật liệu động vật"

msgid "hunt_requirements"
msgstr ""
"Đang ở khu vực thường có động vật, và cảnh giới của avatar phải lớn hơn hoặc "
"bằng cảnh giới của động vật"

# Action: Meditate
msgid "meditate_action_name"
msgstr "Thiền Định"

msgid "meditate_description"
msgstr ""
"Con đường tu luyện của Phật môn. Dùng thiền định để bình phục tâm cảnh, có "
"cơ hội đốn ngộ và nhận được lượng lớn tu vi."

msgid "meditate_requirements"
msgstr "Yêu cầu đạo thống Phật môn"

# Action: Mine
msgid "mine_action_name"
msgstr "Đào Mỏ"

msgid "mine_description"
msgstr "Khai thác khoáng mạch trong khu vực hiện tại để nhận vật liệu khoáng thạch"

msgid "mine_requirements"
msgstr ""
"Đang ở khu vực thường có khoáng mạch, và cảnh giới của avatar phải lớn hơn "
"hoặc bằng cảnh giới của khoáng mạch"

