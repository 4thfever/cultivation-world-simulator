msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Language: vi-VN\n"

msgid "rest_action_name"
msgstr "Nghỉ Ngơi"

msgid "rest_description"
msgstr "Dừng lại điều tức dưỡng thương để hồi phục sinh lực. Quy tộc khi nghỉ ngơi sẽ nhận thêm một ít kinh nghiệm tu vi."

msgid "rest_requirements"
msgstr "Không có yêu cầu đặc biệt."

msgid "eat_mortals_action_name"
msgstr "Ăn Phàm Nhân"

msgid "eat_mortals_description"
msgstr "Yêu tộc lẻn vào nơi phàm nhân tụ cư để nuốt phàm nhân, luyện huyết thực và nỗi sợ thành tu vi."

msgid "eat_mortals_requirements"
msgstr "Cần là yêu tộc và ở khu vực thành thị; phe chính nghĩa thường sẽ không làm việc này."

msgid "Dead avatars cannot rest."
msgstr "Nhân vật đã chết không thể nghỉ ngơi."

msgid "{avatar} withdraws into quiet turtle-breathing rest."
msgstr "{avatar} lui vào nơi yên tĩnh, dùng phép quy tức chậm rãi dưỡng thương."

msgid "{avatar} begins resting."
msgstr "{avatar} bắt đầu nghỉ ngơi."

msgid "{avatar} finished resting, recovered {hp} HP and gained {exp} cultivation experience."
msgstr "{avatar} kết thúc nghỉ ngơi, hồi phục {hp} HP và nhận {exp} kinh nghiệm tu vi."

msgid "{avatar} finished resting and recovered {hp} HP."
msgstr "{avatar} kết thúc nghỉ ngơi và hồi phục {hp} HP."

msgid "Only yao cultivators can eat mortals."
msgstr "Chỉ tu sĩ yêu tộc mới có thể ăn phàm nhân."

msgid "Righteous cultivators will not eat mortals."
msgstr "Tu sĩ phe chính nghĩa sẽ không ăn phàm nhân."

msgid "Can only eat mortals in city areas."
msgstr "Chỉ có thể ăn phàm nhân trong khu vực thành thị."

msgid "There are no mortals here to eat."
msgstr "Ở đây không có phàm nhân để nuốt ăn."

msgid "{avatar} stalks the mortal crowds of {city}."
msgstr "{avatar} lẩn vào đám đông phàm nhân ở {city}, âm thầm tìm huyết thực."

msgid "{avatar} ate {count} mortals in {city}, refining flesh and fear into {exp} cultivation experience."
msgstr "{avatar} đã ăn {count} phàm nhân ở {city}, luyện huyết nhục và nỗi sợ thành {exp} kinh nghiệm tu vi."

msgid "{avatar} follows wild instincts to seek spiritual herbs at {location}"
msgstr "{avatar} lần theo bản năng hoang dã để tìm linh thảo tại {location}"

msgid "{avatar} finished foraging through the wilds, obtained: {materials}"
msgstr "{avatar} đã hái lượm xong trong hoang dã, thu được: {materials}"

msgid "{avatar} begins tracking prey by scent and instinct at {location}"
msgstr "{avatar} bắt đầu lần theo mùi và bản năng để truy tìm con mồi tại {location}"

msgid "{avatar} finished a primal hunt, obtained: {materials}"
msgstr "{avatar} hoàn thành một cuộc săn nguyên thủy, thu được: {materials}"

msgid "effect_extra_rest_exp"
msgstr "Kinh nghiệm tu vi thêm khi nghỉ ngơi"

msgid "effect_extra_rest_hp_recovery_rate"
msgstr "Tỷ lệ hồi HP khi nghỉ ngơi"

msgid "effect_extra_eat_mortals_exp_multiplier"
msgstr "Hệ số kinh nghiệm tu vi khi ăn phàm nhân"

msgid "effect_extra_cross_race_friendliness"
msgstr "Hiệu chỉnh thiện cảm ban đầu khác chủng tộc"
