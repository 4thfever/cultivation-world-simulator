msgid "World is not initialized yet"
msgstr "Thế giới vẫn chưa được khởi tạo"

msgid "Target avatar does not exist"
msgstr "Nhân vật mục tiêu không tồn tại"

msgid "{avatar_name} needs a new command"
msgstr "{avatar_name} cần một chỉ lệnh mới"

msgid "World paused and waiting for your roleplay command."
msgstr "Thế giới đã tạm dừng và đang chờ chỉ lệnh nhập vai của bạn."

msgid "There is already a pending roleplay request"
msgstr "Đã có một yêu cầu nhập vai đang chờ xử lý"

msgid "{avatar_name} needs to make a choice"
msgstr "{avatar_name} cần đưa ra một lựa chọn"

msgid "The other party falls silent for a moment and does not reply immediately."
msgstr "Đối phương im lặng một lát, không lập tức đáp lời."

msgid "{target_avatar_name} pauses to think and responds to the topic."
msgstr "{target_avatar_name} dừng lại suy nghĩ rồi đáp lại chủ đề ấy."

msgid "{avatar_name} and {target_avatar_name} talked for {turns} turns and both gained a new impression of the topic at hand."
msgstr "{avatar_name} và {target_avatar_name} đã trò chuyện qua lại {turns} lượt, cả hai đều có thêm một ấn tượng mới về chủ đề trước mắt."

msgid "{avatar_name} is talking with {target_avatar_name}"
msgstr "{avatar_name} đang trò chuyện với {target_avatar_name}"

msgid "World paused and waiting for you to continue speaking as {avatar_name} with {target_avatar_name}."
msgstr "Thế giới đã tạm dừng, đang chờ bạn tiếp tục lên tiếng với vai {avatar_name} khi trò chuyện cùng {target_avatar_name}."

msgid "There is already another avatar under roleplay control"
msgstr "Đã có một nhân vật khác đang được nhập vai"

msgid "Roleplay target does not match"
msgstr "Mục tiêu nhập vai không khớp"

msgid "The current request is not waiting for a roleplay command"
msgstr "Yêu cầu hiện tại không ở trạng thái chờ chỉ lệnh nhập vai"

msgid "Roleplay request does not exist or has expired"
msgstr "Yêu cầu nhập vai không tồn tại hoặc đã hết hiệu lực"

msgid "Please enter a roleplay command"
msgstr "Vui lòng nhập chỉ lệnh nhập vai"

msgid "Failed to generate a valid action plan from this command"
msgstr "Không thể tạo ra kế hoạch hành động hợp lệ từ chỉ lệnh này"

msgid "Roleplay command submitted"
msgstr "Đã gửi chỉ lệnh nhập vai"

msgid "The current request is not waiting for a roleplay choice"
msgstr "Yêu cầu hiện tại không ở trạng thái chờ lựa chọn nhập vai"

msgid "Roleplay choice state is invalid, please trigger it again"
msgstr "Trạng thái lựa chọn nhập vai không hợp lệ, vui lòng kích hoạt lại"

msgid "This roleplay choice has already been handled"
msgstr "Lựa chọn nhập vai này đã được xử lý"

msgid "Roleplay choice submitted"
msgstr "Đã gửi lựa chọn nhập vai"

msgid "The current request is not in a roleplay conversation"
msgstr "Yêu cầu hiện tại không nằm trong một cuộc đối thoại nhập vai"

msgid "Roleplay conversation request does not exist or has expired"
msgstr "Yêu cầu đối thoại nhập vai không tồn tại hoặc đã hết hiệu lực"

msgid "Roleplay conversation session does not exist or has expired"
msgstr "Phiên đối thoại nhập vai không tồn tại hoặc đã hết hiệu lực"

msgid "Please enter dialogue content"
msgstr "Vui lòng nhập nội dung đối thoại"

msgid "Conversation updated"
msgstr "Đối thoại đã được cập nhật"

msgid "Conversation ended"
msgstr "Đối thoại đã kết thúc"
