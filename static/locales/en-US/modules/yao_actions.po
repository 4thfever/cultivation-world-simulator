msgid "rest_action_name"
msgstr "Rest"

msgid "rest_description"
msgstr "Stop to regulate breath and recover HP. Turtle yao gain a small amount of extra cultivation experience while resting."

msgid "rest_requirements"
msgstr "No special requirements."

msgid "eat_mortals_action_name"
msgstr "Eat Mortals"

msgid "eat_mortals_description"
msgstr "Yao cultivators slip into mortal settlements to devour mortals, refining flesh and fear into cultivation."

msgid "eat_mortals_requirements"
msgstr "Requires a yao cultivator in a city region; righteous cultivators usually will not do this."

msgid "Dead avatars cannot rest."
msgstr "Dead avatars cannot rest."

msgid "{avatar} withdraws into quiet turtle-breathing rest."
msgstr "{avatar} withdraws into quiet turtle-breathing rest."

msgid "{avatar} begins resting."
msgstr "{avatar} begins resting."

msgid "{avatar} finished resting, recovered {hp} HP and gained {exp} cultivation experience."
msgstr "{avatar} finished resting, recovered {hp} HP and gained {exp} cultivation experience."

msgid "{avatar} finished resting and recovered {hp} HP."
msgstr "{avatar} finished resting and recovered {hp} HP."

msgid "Only yao cultivators can eat mortals."
msgstr "Only yao cultivators can eat mortals."

msgid "Righteous cultivators will not eat mortals."
msgstr "Righteous cultivators will not eat mortals."

msgid "Can only eat mortals in city areas."
msgstr "Can only eat mortals in city areas."

msgid "There are no mortals here to eat."
msgstr "There are no mortals here to eat."

